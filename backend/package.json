{
  "name": "songbook-backend",
  "version": "0.0.0",
  "private": true,
  "description": "Songbook backend (Hono Node server)",
  "license": "UNLICENSED",
  "author": "Isabella Skořepová <isabella@skorepova.info>",
  "type": "module",
  "main": "dist/index.js",
  "imports": {
    "#/*": "./src/*"
  },
  "scripts": {
    "build": "webpack",
    "dev": "node --watch src/index.ts",
    "gen:openapi": "node src/gen-openapi.ts",
    "db-push": "pnpm drizzle-kit push:pg --config=drizzle.config.ts",
    "lint": "oxlint",
    "format": "oxfmt",
    "format:check": "oxfmt --check"
  },
  "dependencies": {
    "@hono/node-server": "^2.0.8",
    "@hono/swagger-ui": "^0.6.1",
    "@hono/zod-openapi": "^1.4.0",
    "@planetscale/database": "^1.19.0",
    "bcryptjs": "^3.0.3",
    "buffer": "^6.0.3",
    "crypto-browserify": "^3.12.1",
    "dataloader": "^2.2.3",
    "dotenv": "^17.4.2",
    "drizzle-kit": "^0.31.10",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.27",
    "latinize": "^2.0.0",
    "luxon": "^3.5.0",
    "mysql2": "^3.12.0",
    "node-html-parser": "^8.0.4",
    "pg": "^8.13.1",
    "postgres": "^3.4.5",
    "setimmediate": "^1.0.5",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/latinize": "^0.2.18",
    "@types/luxon": "^3.4.2",
    "@types/node": "^26.1.0",
    "@types/pg": "^8.11.10",
    "nodemon": "^3.1.9",
    "oxfmt": "^0.57.0",
    "oxlint": "^1.72.0",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3"
  },
  "devEngines": {
    "packageManager": {
      "name": "pnpm",
      "version": ">=11.9.0 <12.0.0",
      "onFail": "download"
    },
    "runtime": {
      "name": "node",
      "version": ">=24.14.0 <25.0.0 || >=26.0.0",
      "onFail": "error"
    }
  },
  "engines": {
    "node": ">=24.14.0 <25.0.0 || >=26.0.0"
  }
}
