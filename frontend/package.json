{
  "name": "songbook-frontend",
  "version": "0.1.0",
  "private": true,
  "imports": {
    "#/*": "./src/*"
  },
  "scripts": {
    "build": "vite build",
    "build-ci": "node build-ci.js && vite build",
    "dev": "vite",
    "extract": "node extract.js",
    "gen:api": "pnpm --dir ../backend run gen:openapi ../frontend/src/store/openapi.json && pnpm --filter openapi-codegen run gen",
    "types": "i18next-cli types",
    "lint": "oxlint",
    "format": "oxfmt",
    "format:check": "oxfmt --check"
  },
  "dependencies": {
    "@codemirror/commands": "6.10.4",
    "@codemirror/language": "6.10.4",
    "@isbl/ts-utils": "^1.0.2",
    "@lezer/highlight": "^1.2.3",
    "@lezer/lr": "^1.4.1",
    "@react-pdf/renderer": "^4.5.1",
    "@react-pdf/types": "^2.11.1",
    "@sentry/react": "^10.62.0",
    "@tailwindcss/forms": "^0.5.7",
    "@tailwindcss/typography": "^0.5.13",
    "@tombatossals/chords-db": "^0.5.1",
    "@tombatossals/react-chords": "^0.2.10",
    "@types/file-saver": "^2.0.7",
    "@types/loadable__component": "^5.13.9",
    "@types/luxon": "^3.4.2",
    "@types/react-loadable": "^5.5.11",
    "@types/react-native": "^0.69.23",
    "@uiw/codemirror-themes": "^4.22.1",
    "@uiw/react-codemirror": "^4.22.1",
    "devcert": "^1.2.2",
    "file-saver": "^2.0.5",
    "http-proxy": "^1.18.1",
    "i18next": "^26.3.3",
    "inter-ui": "^4.1.1",
    "localforage": "^1.10.0",
    "luxon": "^3.4.4",
    "openapi-fetch": "^0.17.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-i18next": "^17.0.8",
    "react-loadable": "^5.5.0",
    "react-markdown": "^10.1.0",
    "react-native-web": "0.21.2",
    "react-pdf": "^10.4.1",
    "react-router": "^8.0.1",
    "remark-gfm": "^4.0.0",
    "typescript": "7.0.1-rc",
    "vite": "^8.1.0",
    "vite-plugin-pwa": "^1.3.0",
    "vite-plugin-wasm": "^3.3.0",
    "workbox-core": "^7.4.1",
    "workbox-expiration": "^7.4.1",
    "workbox-precaching": "^7.4.1",
    "workbox-routing": "^7.4.1",
    "workbox-strategies": "^7.4.1",
    "workbox-window": "^7.1.0",
    "xorshift": "^1.2.0"
  },
  "devDependencies": {
    "@lezer/generator": "^1.7.0",
    "@tailwindcss/postcss": "^4.3.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "i18next-cli": "^1.64.2",
    "oxfmt": "^0.56.0",
    "oxlint": "^1.71.0",
    "postcss": "^8.4.38",
    "tailwindcss": "^4.3.1"
  },
  "babel": {
    "presets": [
      "react-app"
    ]
  },
  "browserslist": [
    ">0.2%",
    "not dead",
    "not ie <= 11",
    "not op_mini all"
  ],
  "devEngines": {
    "packageManager": {
      "name": "pnpm",
      "version": ">=11.9.0 <12.0.0",
      "onFail": "download"
    }
  }
}
