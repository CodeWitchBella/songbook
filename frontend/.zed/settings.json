{
  "auto_install_extensions": {
    "tsgo": true
  },
  "lsp": {
    "tsgo": {
      "binary": {
        "ignore_system_version": true,
        "path": "frontend/node_modules/.bin/tsc",
        "arguments": ["--lsp", "-stdio"]
      }
    }
  },
  "languages": {
    "JavaScript": {
      "language_servers": ["tsgo", "!vtsls", "!typescript-language-server", "..."],
      "formatter": {
        "external": {
          "command": "node_modules/.bin/oxfmt",
          "arguments": ["--stdin-filepath={buffer_path}"]
        }
      }
    },
    "TypeScript": {
      "language_servers": ["tsgo", "!vtsls", "!typescript-language-server", "..."],
      "formatter": {
        "external": {
          "command": "node_modules/.bin/oxfmt",
          "arguments": ["--stdin-filepath={buffer_path}"]
        }
      }
    },
    "TSX": {
      "language_servers": ["tsgo", "!vtsls", "!typescript-language-server", "..."],
      "formatter": {
        "external": {
          "command": "node_modules/.bin/oxfmt",
          "arguments": ["--stdin-filepath={buffer_path}"]
        }
      }
    },
    "JSX": {
      "language_servers": ["tsgo", "!vtsls", "!typescript-language-server", "..."],
      "formatter": {
        "external": {
          "command": "node_modules/.bin/oxfmt",
          "arguments": ["--stdin-filepath={buffer_path}"]
        }
      }
    }
  }
}
