{
  "languages": {
    "JavaScript": {
      "formatter": {
        "external": {
          "command": "frontend/node_modules/.bin/oxfmt",
          "arguments": ["--stdin-filepath={buffer_path}"]
        }
      },
      "language_servers": ["!vtsls", "!eslint", "!biome", "oxc", "..."]
    },
